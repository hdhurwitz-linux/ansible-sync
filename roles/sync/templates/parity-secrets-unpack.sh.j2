#!/usr/bin/env bash
set -euo pipefail

user_name="$1"
home_dir="$(getent passwd "$user_name" | cut -d: -f6)"
if [[ -z "$home_dir" ]]; then
  echo "Unable to resolve home directory for user: $user_name" >&2
  exit 1
fi

encrypted_archive="{{ sync_secret_encrypted_archive }}"
identity_file="{{ sync_age_identity_file }}"
state_dir="{{ sync_state_dir }}"
plain_archive="${state_dir}/secret-vaults.latest.tar.zst"
stamp_file="${state_dir}/secret-vaults.applied.sha256"

mkdir -p "$state_dir"

if [[ ! -f "$encrypted_archive" ]]; then
  exit 0
fi

if [[ ! -f "$identity_file" ]]; then
  echo "Age identity file not found ($identity_file); cannot decrypt yet." >&2
  exit 0
fi

new_hash="$(sha256sum "$encrypted_archive" | awk '{print $1}')"
old_hash=""
if [[ -f "$stamp_file" ]]; then
  old_hash="$(cat "$stamp_file" 2>/dev/null || true)"
fi

if [[ "$new_hash" == "$old_hash" ]]; then
  exit 0
fi

age --decrypt -i "$identity_file" -o "$plain_archive" "$encrypted_archive"
tar --zstd -xf "$plain_archive" --absolute-names
printf '%s' "$new_hash" > "$stamp_file"
