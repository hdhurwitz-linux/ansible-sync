#!/usr/bin/env bash
set -euo pipefail

user_name="$1"
home_dir="$(getent passwd "$user_name" | cut -d: -f6)"
if [[ -z "$home_dir" ]]; then
  echo "Unable to resolve home directory for user: $user_name" >&2
  exit 1
fi

state_dir="{{ sync_state_dir }}"
plain_archive="{{ sync_secret_plain_archive }}"
encrypted_archive="{{ sync_secret_encrypted_archive }}"
recipient_file="/etc/parity-sync/${user_name}.recipient"
paths_file="/etc/parity-sync/${user_name}.paths"

mkdir -p "$(dirname "$plain_archive")" "$(dirname "$encrypted_archive")"

if [[ ! -s "$recipient_file" ]]; then
  echo "No age recipients configured in $recipient_file; skipping pack." >&2
  exit 0
fi

mapfile -t recipients < <(grep -v '^\s*$' "$recipient_file" | tr -d '\r')
if [[ "$(printf '%s\n' "${recipients[@]}" | sed '/^$/d' | wc -l)" -eq 0 ]]; then
  echo "Recipients file is empty; skipping pack." >&2
  exit 0
fi

if [[ ! -f "$paths_file" ]]; then
  echo "Path manifest missing: $paths_file" >&2
  exit 0
fi

tmp_list="$(mktemp)"
trap 'rm -f "$tmp_list"' EXIT

while IFS= read -r raw_path; do
  [[ -z "$raw_path" ]] && continue
  resolved_path="$raw_path"
  if [[ -e "$resolved_path" ]]; then
    printf '%s\n' "$resolved_path" >> "$tmp_list"
  fi
done < "$paths_file"

if [[ ! -s "$tmp_list" ]]; then
  echo "No source paths exist yet; skipping pack." >&2
  exit 0
fi

tar --zstd -cf "$plain_archive" --absolute-names --files-from "$tmp_list"

age_args=()
for recipient in "${recipients[@]}"; do
  age_args+=("-r" "$recipient")
done

age "${age_args[@]}" -o "$encrypted_archive" "$plain_archive"
