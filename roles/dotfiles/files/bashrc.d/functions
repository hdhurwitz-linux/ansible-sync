#!/bin/bash
# Common bash functions

# Find in history
hf() {
    history | grep "$@" | tail -20
}

# Make and cd
mkcd() {
    mkdir -p "$@" && cd "$_"
}

# Quick backup
backup() {
    cp "$1" "$1.bak.$(date +%s)"
}

# Show recent files
recent() {
    find . -type f -printf '%T@ %p\n' | sort -rn | head -10 | cut -d' ' -f2-
}
