{
    "name": "ansible-sync-codespace",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "username": "vscode"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "files.eol": "\n",
                "ansible.validation.enabled": true,
                "yaml.schemas": {
                    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
                }
            },
            "extensions": [
                "redhat.ansible",
                "redhat.vscode-yaml",
                "ms-python.python",
                "ms-vscode.makefile-tools",
                "GitHub.vscode-pull-request-github"
            ]
        }
    },
    "postCreateCommand": "bash -lc 'set -e; pipx ensurepath; pipx install --force ansible-core; ~/.local/bin/ansible-galaxy collection install --force community.general; ~/.local/bin/ansible --version'",
    "remoteEnv": {
        "ANSIBLE_CONFIG": "${containerWorkspaceFolder}/ansible.cfg"
    }
}