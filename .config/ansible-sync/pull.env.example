# GitHub source-of-truth for all machines
ANSIBLE_SYNC_REPO_URL="https://github.com/YOUR_ORG/ansible-sync.git"
ANSIBLE_SYNC_REPO_BRANCH="main"

# Local checkout path used by ansible-pull
ANSIBLE_SYNC_CHECKOUT_DIR="$HOME/ansible-sync-pull"

# Inventory and playbook within the pulled repo
ANSIBLE_SYNC_INVENTORY="inventory"
ANSIBLE_SYNC_PLAYBOOK="playbooks/full_sync.yml"

# Optional vault password file path for encrypted secrets
ANSIBLE_SYNC_VAULT_PASS_FILE="$HOME/.config/ansible-sync/vault-pass.txt"
